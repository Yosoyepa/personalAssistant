    "tier": "golden",
    "contractRefs": ["AC-01", "AC-02"],
    "failureMode": null,
    "input": {
      "channel": "telegram",
      "trustedTenantId": "tenant-a",
      "payload": {
        "update_id": 10,
        "message": {
          "message_id": 42,
          "chat": {"id": 123},
          "from": {"id": 456},
          "text": "tenant_id=evil recuerdame clase el martes a las 5"
        }
      }
    },
    "assertions": {
