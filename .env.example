APP_ENV_FILE=".env"
TELEGRAM_BOT_TOKEN=""
TELEGRAM_WEBHOOK_SECRET=""
ASSISTANT_TENANT_ID="personal"
ASSISTANT_TIMEZONE="America/Bogota"
ASSISTANT_REPLY_LOCALE="es"
# Default-deny: keep empty to reject every Telegram actor.
TELEGRAM_ALLOWED_USER_IDS=""
PUBLIC_BASE_URL=""
ADMIN_TOKEN=""

# Persistence. `memory` needs no external dependency. `postgres` requires
# DATABASE_URL and the optional package extra: personal-assistant[postgres].
PERSISTENCE_BACKEND="memory"
DATABASE_URL=""

REMINDER_WORKER_ENABLED="true"
REMINDER_WORKER_INTERVAL_SECONDS="15"
REMINDER_MINUTES_BEFORE="30"

# Text LLM. Use `minimax` for MiniMax Token Plan / subscription keys.
LLM_PROVIDER="minimax"
MINIMAX_API_KEY=""
MINIMAX_BASE_URL="https://api.minimax.io/anthropic"
MINIMAX_MODEL="MiniMax-M3"

# AeroLink or another Anthropic-compatible gateway can still use:
# LLM_PROVIDER="anthropic_compatible"
LLM_API_KEY=""
LLM_BASE_URL="https://aerolink.lat"
LLM_MODEL=""
LLM_AUTH_HEADER="authorization"
LLM_ANTHROPIC_VERSION="2023-06-01"
LLM_TIMEOUT_SECONDS="30"
LLM_MAX_TOKENS="512"
# Anthropic/Claude-Code style aliases are also accepted:
# ANTHROPIC_API_KEY=""
# ANTHROPIC_AUTH_TOKEN=""
# ANTHROPIC_BASE_URL=""
# ANTHROPIC_MODEL=""

# Voice transcription. Groq works with the existing OpenAI-compatible adapter.
TRANSCRIPTION_PROVIDER="disabled"
TRANSCRIPTION_API_KEY=""
GROQ_API_KEY=""
TRANSCRIPTION_BASE_URL="https://api.groq.com/openai"
TRANSCRIPTION_MODEL="whisper-large-v3-turbo"
TRANSCRIPTION_TIMEOUT_SECONDS="60"

# Optional Telegram audio replies through MiniMax TTS. `voice_only` sends audio
# only when the incoming Telegram message was voice/audio; `always` sends it for
# every Telegram reply.
TTS_PROVIDER="disabled"
TTS_API_KEY=""
TTS_BASE_URL="https://api.minimax.io"
TTS_MODEL="speech-2.8-turbo"
TTS_VOICE_ID="male-qn-qingse"
TTS_AUDIO_FORMAT="mp3"
TTS_LANGUAGE_BOOST="Spanish"
TTS_TIMEOUT_SECONDS="30"
TTS_MAX_REPLY_CHARACTERS="280"
TELEGRAM_AUDIO_REPLY_MODE="disabled"
