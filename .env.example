TELEGRAM_BOT_TOKEN=""
TELEGRAM_WEBHOOK_SECRET=""
ASSISTANT_TENANT_ID="personal"
ASSISTANT_TIMEZONE="America/Bogota"
TELEGRAM_ALLOWED_USER_IDS=""
PUBLIC_BASE_URL=""
ADMIN_TOKEN=""
REMINDER_WORKER_INTERVAL_SECONDS="15"

# Text LLM. AeroLink is expected to work here only if it exposes an
# Anthropic Messages API compatible /v1/messages endpoint.
LLM_PROVIDER="anthropic_compatible"
LLM_API_KEY=""
LLM_BASE_URL="https://aerolink.lat"
LLM_MODEL=""
LLM_AUTH_HEADER="x-api-key"
LLM_ANTHROPIC_VERSION="2023-06-01"
LLM_TIMEOUT_SECONDS="30"
LLM_MAX_TOKENS="512"
# Anthropic/Claude-Code style aliases are also accepted:
# ANTHROPIC_API_KEY=""
# ANTHROPIC_AUTH_TOKEN=""
# ANTHROPIC_BASE_URL=""
# ANTHROPIC_MODEL=""

# Voice transcription. Configure this only if AeroLink, or another provider,
# exposes an OpenAI-style /v1/audio/transcriptions endpoint.
TRANSCRIPTION_PROVIDER="disabled"
TRANSCRIPTION_API_KEY=""
TRANSCRIPTION_BASE_URL=""
TRANSCRIPTION_MODEL=""
TRANSCRIPTION_TIMEOUT_SECONDS="60"
